generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ── User ─────────────────────────────────────────────────────────────────────
// Thin record linking a Clerk identity to a Stripe customer.
model User {
  id               String        @id @default(cuid())
  clerkId          String        @unique
  email            String        @unique
  username         String?       @unique
  stripeCustomerId String?       @unique
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  subscription     Subscription?
}

// ── Subscription ──────────────────────────────────────────────────────────────
// Mirrored from Stripe via webhooks. Source of truth for feature gating.
model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String    @unique
  stripePriceId        String
  status               String    // trialing | active | past_due | canceled | unpaid | incomplete | incomplete_expired
  currentPeriodEnd     DateTime
  trialEnd             DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([status])
}

// ── GameResult ──────────────────────────────────────────────────────────────
// Stores every GAME_OVER postMessage from iframe games.
// One row per user per game per day (upserts on replay for arcade).
model GameResult {
  id           String   @id @default(cuid())
  game         String
  gameType     String   // "puzzle" | "arcade"
  userId       String
  date         String   // YYYY-MM-DD (UTC)
  puzzleNumber Int
  score        Int
  completed    Boolean
  shareText    String?
  streak       Int      @default(0)
  maxStreak    Int      @default(0)
  smgVersion   String   @default("1.1")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([game, userId, date])
  @@index([game, date])
  @@index([userId])
}

model LeaderboardScore {
  id        String   @id @default(cuid())
  game      String
  userId    String
  userName  String
  score     Int
  lines     Int      @default(0)
  level     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([game, userId])
  @@index([game, score])
}
